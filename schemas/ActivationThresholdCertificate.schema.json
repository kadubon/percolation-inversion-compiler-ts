{
  "$defs": {
    "ActivationConstructionCertificate": {
      "properties": {
        "configuration_space_size": {
          "title": "Configuration Space Size",
          "type": "integer"
        },
        "construction_id": {
          "title": "Construction Id",
          "type": "string"
        },
        "energy_ledger_present": {
          "default": false,
          "title": "Energy Ledger Present",
          "type": "boolean"
        },
        "exact": {
          "default": false,
          "title": "Exact",
          "type": "boolean"
        },
        "sampler_residual": {
          "default": 0.0,
          "title": "Sampler Residual",
          "type": "number"
        }
      },
      "required": [
        "construction_id",
        "configuration_space_size"
      ],
      "title": "ActivationConstructionCertificate",
      "type": "object"
    },
    "CapabilityEdge": {
      "properties": {
        "activation_weight": {
          "default": 1.0,
          "title": "Activation Weight",
          "type": "number"
        },
        "burden": {
          "default": 0.0,
          "title": "Burden",
          "type": "number"
        },
        "edge_id": {
          "title": "Edge Id",
          "type": "string"
        },
        "required_capacity": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Required Capacity",
          "type": "object"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/ClaimStatus",
          "default": "provisional"
        },
        "target": {
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "sources",
        "target"
      ],
      "title": "CapabilityEdge",
      "type": "object"
    },
    "CapabilityHypergraph": {
      "properties": {
        "edges": {
          "items": {
            "$ref": "#/$defs/CapabilityEdge"
          },
          "title": "Edges",
          "type": "array"
        },
        "nodes": {
          "items": {
            "type": "string"
          },
          "title": "Nodes",
          "type": "array",
          "uniqueItems": true
        },
        "seed_mass": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Seed Mass",
          "type": "object"
        }
      },
      "title": "CapabilityHypergraph",
      "type": "object"
    },
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    }
  },
  "properties": {
    "activation": {
      "$ref": "#/$defs/ActivationConstructionCertificate"
    },
    "certificate_id": {
      "title": "Certificate Id",
      "type": "string"
    },
    "finite_size": {
      "default": 0,
      "title": "Finite Size",
      "type": "integer"
    },
    "graph": {
      "$ref": "#/$defs/CapabilityHypergraph"
    },
    "lower_bounds": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Lower Bounds",
      "type": "object"
    },
    "residual": {
      "default": 0.0,
      "title": "Residual",
      "type": "number"
    },
    "target_nodes": {
      "items": {
        "type": "string"
      },
      "title": "Target Nodes",
      "type": "array",
      "uniqueItems": true
    },
    "thermodynamic_obligation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Thermodynamic Obligation Ids",
      "type": "array",
      "uniqueItems": true
    },
    "threshold": {
      "default": 0.0,
      "title": "Threshold",
      "type": "number"
    }
  },
  "required": [
    "certificate_id",
    "activation",
    "graph"
  ],
  "title": "ActivationThresholdCertificate",
  "type": "object"
}
