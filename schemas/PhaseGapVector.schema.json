      "type": "boolean"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "vector_id": {
      "default": "phase-gap-vector",
      "title": "Vector Id",
      "type": "string"
    }
