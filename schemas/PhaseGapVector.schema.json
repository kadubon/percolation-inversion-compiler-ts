          "title": "Limiting",
          "type": "boolean"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "source": {
          "default": "PsiDashboard",
          "title": "Source",
          "type": "string"
        },
        "threshold_value": {
          "default": 0.0,
          "title": "Threshold Value",
          "type": "number"
        }
      },
      "required": [
