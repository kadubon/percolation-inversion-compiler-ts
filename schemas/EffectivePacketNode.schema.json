    },
    "eligibility": {
      "$ref": "#/$defs/EffectivePacketEligibility"
    },
    "missing_obligations": {
      "items": {
        "type": "string"
      },
      "title": "Missing Obligations",
      "type": "array"
    },
    "node_id": {
      "title": "Node Id",
      "type": "string"
    },
    "operationally_usable": {
      "default": false,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "residual_summary": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Residual Summary",
      "type": "object"
    },
    "schema_hint": {
      "default": "unknown",
      "title": "Schema Hint",
      "type": "string"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "source_event_id": {
      "default": "",
      "title": "Source Event Id",
      "type": "string"
    },
    "source_kind": {
      "default": "unknown-report",
      "title": "Source Kind",
      "type": "string"
    },
    "workflow_usable": {
      "default": false,
      "title": "Workflow Usable",
      "type": "boolean"
    }
  },
  "required": [
    "node_id"
  ],
  "title": "EffectivePacketNode",
  "type": "object"
}
