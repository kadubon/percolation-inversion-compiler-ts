{
  "$defs": {
    "PhaseComponentGap": {
      "description": "One finite gap between a phase proxy component and its threshold.",
      "properties": {
        "component": {
          "title": "Component",
          "type": "string"
        },
        "current_value": {
          "default": 0.0,
          "title": "Current Value",
          "type": "number"
        },
        "gap": {
          "default": 0.0,
          "title": "Gap",
          "type": "number"
        },
        "limiting": {
          "default": false,
          "title": "Limiting",
          "type": "boolean"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "source": {
          "default": "PsiDashboard",
          "title": "Source",
          "type": "string"
        },
        "threshold_value": {
          "default": 0.0,
          "title": "Threshold Value",
          "type": "number"
        }
      },
      "required": [
        "component"
      ],
      "title": "PhaseComponentGap",
      "type": "object"
    },
    "PhaseGapVector": {
      "description": "Portable vector of remaining protocol-relative phase gaps.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "aggregate_gap": {
          "default": 0.0,
          "title": "Aggregate Gap",
          "type": "number"
        },
        "components": {
          "items": {
            "$ref": "#/$defs/PhaseComponentGap"
          },
          "title": "Components",
          "type": "array"
        },
        "limiting_components": {
          "items": {
            "type": "string"
          },
          "title": "Limiting Components",
          "type": "array"
        },
        "operationally_usable": {
          "default": false,
          "title": "Operationally Usable",
          "type": "boolean"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        },
        "vector_id": {
          "default": "phase-gap-vector",
          "title": "Vector Id",
          "type": "string"
        }
      },
      "title": "PhaseGapVector",
      "type": "object"
    }
  },
