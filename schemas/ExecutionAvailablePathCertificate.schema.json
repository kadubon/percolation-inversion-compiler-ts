{
  "$defs": {
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "description": "Finite certificate that a path is execution-available but not executed.",
  "properties": {
    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "authority_granted": {
      "default": true,
      "title": "Authority Granted",
      "type": "boolean"
    },
    "certificate_id": {
      "title": "Certificate Id",
      "type": "string"
    },
    "constraint_frame_id": {
      "default": "default-constraint-frame",
      "title": "Constraint Frame Id",
      "type": "string"
    },
    "edge_ids": {
      "items": {
        "type": "string"
      },
      "title": "Edge Ids",
      "type": "array"
    },
    "evidence_refs": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "execution_gates": {
      "items": {
        "type": "string"
      },
      "title": "Execution Gates",
      "type": "array"
    },
    "finite_checks_passed": {
      "default": false,
      "title": "Finite Checks Passed",
      "type": "boolean"
    },
    "not_executed": {
      "default": true,
      "title": "Not Executed",
      "type": "boolean"
    },
    "operationally_usable": {
      "default": false,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "packet_ids": {
      "items": {
        "type": "string"
      },
      "title": "Packet Ids",
      "type": "array"
    },
    "path_id": {
      "title": "Path Id",
      "type": "string"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "receiver_context": {
      "items": {
        "type": "string"
      },
      "title": "Receiver Context",
      "type": "array"
    },
    "residual_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "rollback_available": {
      "default": true,
      "title": "Rollback Available",
      "type": "boolean"
    },
    "route_ids": {
      "items": {
        "type": "string"
      },
      "title": "Route Ids",
      "type": "array"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    }
  },
  "required": [
    "certificate_id",
    "path_id"
  ],
  "title": "ExecutionAvailablePathCertificate",
  "type": "object"
}
