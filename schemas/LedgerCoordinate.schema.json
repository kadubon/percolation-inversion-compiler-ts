{
  "$defs": {
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    }
  },
  "description": "One typed coordinate in a finite certificate ledger.",
  "properties": {
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "evidence_refs": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "evidence_status": {
      "$ref": "#/$defs/EvidenceStatus",
      "default": "declared"
    },
    "kind": {
      "$ref": "#/$defs/CoordinateKind",
      "default": "burden"
    },
    "known": {
      "default": true,
      "title": "Known",
      "type": "boolean"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "unit": {
      "default": "dimensionless",
      "title": "Unit",
      "type": "string"
    },
    "value": {
      "title": "Value",
      "type": "number"
    }
  },
  "required": [
    "name",
    "value"
  ],
  "title": "LedgerCoordinate",
  "type": "object"
}
