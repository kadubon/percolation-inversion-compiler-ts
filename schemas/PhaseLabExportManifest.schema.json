        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        },
        "store_id": {
          "default": "phase-lab-store",
          "title": "Store Id",
          "type": "string"
        },
        "store_path": {
          "default": "",
          "title": "Store Path",
          "type": "string"
        },
        "window_count": {
          "default": 0,
          "title": "Window Count",
          "type": "integer"
        }
      },
      "title": "PhaseLabStoreManifest",
      "type": "object"
    }
  },
  "description": "Manifest for a deterministic local Phase Lab export.",
  "properties": {
    "absolute_paths_sanitized": {
      "default": true,
      "title": "Absolute Paths Sanitized",
      "type": "boolean"
    },
    "accepted": {
      "default": true,
      "title": "Accepted",
      "type": "boolean"
    },
    "export_id": {
      "default": "phase-lab-export",
      "title": "Export Id",
      "type": "string"
    },
