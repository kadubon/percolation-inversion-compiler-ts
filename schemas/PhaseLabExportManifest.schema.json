        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "safety_invariants": {
          "items": {
            "type": "string"
          },
          "title": "Safety Invariants",
          "type": "array"
        },
        "schema_version": {
          "default": "phase-lab-store-v1",
          "title": "Schema Version",
          "type": "string"
