      "items": {
        "type": "string"
      },
      "title": "Files",
      "type": "array"
    },
    "output_dir": {
      "default": "",
      "title": "Output Dir",
      "type": "string"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "store_manifest": {
