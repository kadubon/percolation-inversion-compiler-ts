{
  "$defs": {
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "description": "Observed finite trace from which an abstraction token may be extracted.",
  "properties": {
    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "action_refs": {
      "items": {
        "type": "string"
      },
      "title": "Action Refs",
      "type": "array"
    },
    "cost_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "observation_refs": {
      "items": {
        "type": "string"
      },
      "title": "Observation Refs",
      "type": "array"
    },
    "provenance_refs": {
      "items": {
        "type": "string"
      },
      "title": "Provenance Refs",
      "type": "array"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "receiver_family": {
      "items": {
        "type": "string"
      },
      "title": "Receiver Family",
      "type": "array"
    },
    "result_refs": {
      "items": {
        "type": "string"
      },
      "title": "Result Refs",
      "type": "array"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "trace_id": {
      "title": "Trace Id",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "task_id"
  ],
  "title": "ProblemSolvingTrace",
  "type": "object"
}
