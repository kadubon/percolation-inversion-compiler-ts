{
  "$defs": {
    "CertificateRoute": {
      "description": "Finite construction, verification, or settlement route.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "cost": {
          "$ref": "#/$defs/Ledger"
        },
        "failure_mode": {
          "default": "route-not-accepted",
          "title": "Failure Mode",
          "type": "string"
        },
        "obligation_id": {
          "title": "Obligation Id",
          "type": "string"
        },
        "residual": {
          "$ref": "#/$defs/Ledger"
        },
        "route_id": {
          "title": "Route Id",
          "type": "string"
        }
      },
      "required": [
        "route_id",
        "obligation_id"
      ],
      "title": "CertificateRoute",
      "type": "object"
    },
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "ExternalProofObligation": {
      "description": "A non-finite or domain-specific proof obligation exposed to callers.",
      "properties": {
        "accepted_evidence_kind": {
          "items": {
            "type": "string"
          },
          "title": "Accepted Evidence Kind",
          "type": "array"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "failure_mode": {
          "default": "proof-obligation-unmet",
          "title": "Failure Mode",
          "type": "string"
        },
        "failure_modes": {
          "items": {
            "type": "string"
          },
          "title": "Failure Modes",
          "type": "array"
        },
        "obligation_category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Obligation Category"
        },
        "obligation_id": {
          "title": "Obligation Id",
          "type": "string"
        },
        "required_for_status": {
          "$ref": "#/$defs/ClaimStatus",
          "default": "settled"
        },
        "residual_charge": {
          "$ref": "#/$defs/Ledger"
        },
        "residual_policy": {
          "default": "charge-residual-until-verified",
          "title": "Residual Policy",
          "type": "string"
        },
        "safe_default": {
          "default": "diagnostic-with-proof-obligation",
          "title": "Safe Default",
          "type": "string"
        },
        "schema_refs": {
          "items": {
            "type": "string"
          },
          "title": "Schema Refs",
          "type": "array"
        },
        "verifier_contract": {
          "additionalProperties": true,
          "title": "Verifier Contract",
          "type": "object"
        },
        "verifier_hint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Verifier Hint"
        }
      },
      "required": [
        "obligation_id",
        "description"
      ],
      "title": "ExternalProofObligation",
      "type": "object"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    },
    "ObligationRule": {
      "description": "A portable finite obligation rule used to derive checker status.",
      "properties": {
        "external_obligation_ids": {
          "items": {
            "type": "string"
          },
          "title": "External Obligation Ids",
          "type": "array",
          "uniqueItems": true
        },
        "hard_domain_obligations": {
          "items": {
            "type": "string"
          },
          "title": "Hard Domain Obligations",
          "type": "array",
          "uniqueItems": true
        },
        "required_for_provisional": {
          "items": {
            "type": "string"
          },
          "title": "Required For Provisional",
          "type": "array",
          "uniqueItems": true
        },
        "required_for_settled": {
          "items": {
            "type": "string"
          },
          "title": "Required For Settled",
          "type": "array",
          "uniqueItems": true
        },
        "required_for_speculative": {
          "items": {
            "type": "string"
          },
          "title": "Required For Speculative",
          "type": "array",
          "uniqueItems": true
        },
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        }
      },
      "required": [
        "rule_id"
      ],
      "title": "ObligationRule",
      "type": "object"
    },
    "RefreshRule": {
      "description": "Finite expiry/refresh rule for certificate routes.",
      "properties": {
        "expired_obligations": {
          "items": {
            "type": "string"
          },
          "title": "Expired Obligations",
          "type": "array",
          "uniqueItems": true
        },
        "live_obligations": {
          "items": {
            "type": "string"
          },
          "title": "Live Obligations",
          "type": "array",
          "uniqueItems": true
        },
        "refresh_obligations": {
          "items": {
            "type": "string"
          },
          "title": "Refresh Obligations",
          "type": "array",
          "uniqueItems": true
        }
      },
      "title": "RefreshRule",
      "type": "object"
    }
  },
  "description": "A finite certificate family with construction/verifier/settlement routes.",
  "properties": {
    "construction_routes": {
      "items": {
        "$ref": "#/$defs/CertificateRoute"
      },
      "title": "Construction Routes",
      "type": "array"
    },
    "external_obligations": {
      "items": {
        "$ref": "#/$defs/ExternalProofObligation"
      },
      "title": "External Obligations",
      "type": "array"
    },
    "family_id": {
      "title": "Family Id",
      "type": "string"
    },
    "refresh_rule": {
      "$ref": "#/$defs/RefreshRule"
    },
    "settlement_routes": {
      "items": {
        "$ref": "#/$defs/CertificateRoute"
      },
      "title": "Settlement Routes",
      "type": "array"
    },
    "status_rule": {
      "anyOf": [
        {
          "$ref": "#/$defs/ObligationRule"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "verifier_routes": {
      "items": {
        "$ref": "#/$defs/CertificateRoute"
      },
      "title": "Verifier Routes",
      "type": "array"
    }
  },
  "required": [
    "family_id"
  ],
  "title": "CertificateFamily",
  "type": "object"
}
