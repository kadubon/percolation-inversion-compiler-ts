      "items": {
        "type": "string"
      },
      "title": "Remaining Friction Points",
      "type": "array"
    },
    "report_id": {
      "default": "agent-autonomy-audit",
      "title": "Report Id",
      "type": "string"
    },
    "safe_commands_executable_by_pic": {
      "default": false,
      "title": "Safe Commands Executable By Pic",
      "type": "boolean"
    },
    "safety_invariants": {
      "items": {
        "type": "string"
      },
      "title": "Safety Invariants",
      "type": "array"
