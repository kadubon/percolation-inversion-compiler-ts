    "accepted": {
      "default": true,
      "title": "Accepted",
      "type": "boolean"
    },
    "adoption_required_for_core": {
      "default": false,
      "title": "Adoption Required For Core",
      "type": "boolean"
    },
    "agent_full_extra_available": {
      "default": true,
      "title": "Agent Full Extra Available",
      "type": "boolean"
    },
    "approval_gate_present": {
      "default": false,
      "title": "Approval Gate Present",
      "type": "boolean"
    },
    "approval_persistence_created": {
      "default": false,
      "title": "Approval Persistence Created",
      "type": "boolean"
    },
    "autonomy_enablers": {
      "items": {
        "type": "string"
      },
      "title": "Autonomy Enablers",
      "type": "array"
    },
    "background_crawling_allowed": {
      "default": false,
      "title": "Background Crawling Allowed",
      "type": "boolean"
    },
    "command_execution_allowed_by_pic": {
      "default": false,
      "title": "Command Execution Allowed By Pic",
      "type": "boolean"
    },
    "compact_mode_available": {
      "default": true,
      "title": "Compact Mode Available",
      "type": "boolean"
    },
    "operationally_usable": {
      "default": true,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "pip_agent_full_commands": {
      "items": {
        "type": "string"
      },
      "title": "Pip Agent Full Commands",
      "type": "array"
    },
    "pip_core_commands": {
      "items": {
        "type": "string"
      },
      "title": "Pip Core Commands",
      "type": "array"
    },
    "pip_core_workflow_available": {
      "default": true,
      "title": "Pip Core Workflow Available",
      "type": "boolean"
    },
    "profile": {
      "default": "development",
      "title": "Profile",
      "type": "string"
    },
    "reasons": {
