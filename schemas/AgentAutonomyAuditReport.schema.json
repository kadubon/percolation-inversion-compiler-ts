        "type": "string"
      },
      "title": "Source Checkout Commands",
      "type": "array"
    },
    "source_checkout_required_for_core": {
      "default": false,
      "title": "Source Checkout Required For Core",
      "type": "boolean"
    },
    "workflow_usable": {
      "default": true,
      "title": "Workflow Usable",
      "type": "boolean"
    }
  },
  "title": "AgentAutonomyAuditReport",
  "type": "object"
}
