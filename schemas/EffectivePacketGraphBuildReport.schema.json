  "description": "Build report for an effective packet graph.",
  "properties": {
    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "diagnostic_only_count": {
      "default": 0,
      "title": "Diagnostic Only Count",
      "type": "integer"
    },
    "graph": {
      "$ref": "#/$defs/EffectivePacketGraph"
    },
    "input_event_count": {
      "default": 0,
      "title": "Input Event Count",
      "type": "integer"
    },
    "positive_contribution_count": {
      "default": 0,
      "title": "Positive Contribution Count",
      "type": "integer"
    },
    "raw_volume_positive_contribution": {
      "default": 0,
      "title": "Raw Volume Positive Contribution",
      "type": "integer"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "report_id": {
      "default": "effective-packet-graph-build",
      "title": "Report Id",
      "type": "string"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "workflow_usable": {
      "default": false,
      "title": "Workflow Usable",
      "type": "boolean"
    }
