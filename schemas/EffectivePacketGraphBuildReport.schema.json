        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "residual_summary": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Residual Summary",
          "type": "object"
        },
