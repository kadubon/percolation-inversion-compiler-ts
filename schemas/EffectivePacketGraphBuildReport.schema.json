{
  "$defs": {
    "EffectiveGraphResidualSummary": {
      "description": "Residual summary carried by an effective graph.",
      "properties": {
        "candidate_only_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Candidate Only Reasons",
          "type": "array"
        },
        "missing_obligation_count": {
          "default": 0,
          "title": "Missing Obligation Count",
          "type": "integer"
        },
        "residual_debt": {
          "default": 0.0,
          "title": "Residual Debt",
          "type": "number"
        },
        "residual_summary": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Residual Summary",
          "type": "object"
        },
        "settled_blockers": {
          "items": {
            "type": "string"
          },
          "title": "Settled Blockers",
          "type": "array"
        }
      },
      "title": "EffectiveGraphResidualSummary",
      "type": "object"
    },
    "EffectivePacketEdge": {
      "description": "One edge in the effective packet graph.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "contribution": {
          "$ref": "#/$defs/PacketContributionStatus"
        },
        "edge_id": {
          "title": "Edge Id",
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/SemanticEdgeEvidence"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "relation_type": {
          "default": "semantic-dependency",
          "title": "Relation Type",
          "type": "string"
        },
        "residual_summary": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Residual Summary",
          "type": "object"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        },
        "source_node_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Node Ids",
          "type": "array"
        },
        "target_node_id": {
          "title": "Target Node Id",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "target_node_id"
      ],
      "title": "EffectivePacketEdge",
      "type": "object"
    },
