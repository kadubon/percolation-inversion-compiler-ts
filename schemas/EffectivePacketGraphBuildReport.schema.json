        "stale_or_unsafe_packets": {
          "items": {
            "type": "string"
          },
          "title": "Stale Or Unsafe Packets",
          "type": "array"
        },
        "workflow_usable": {
          "default": false,
          "title": "Workflow Usable",
          "type": "boolean"
        }
      },
      "title": "EffectivePacketGraph",
      "type": "object"
    },
    "EffectivePacketNode": {
      "description": "One node in the effective packet graph.",
