{
  "$defs": {
    "BottleneckIntervention": {
      "description": "One ranked bottleneck-inversion intervention.",
      "properties": {
        "action_kind": {
          "title": "Action Kind",
          "type": "string"
        },
        "expected_gain": {
          "default": 0.0,
          "title": "Expected Gain",
          "type": "number"
        },
        "intervention_id": {
          "title": "Intervention Id",
          "type": "string"
        },
        "post_intervention_horizon": {
          "default": 1,
          "title": "Post Intervention Horizon",
          "type": "integer"
        },
        "required_routes": {
          "items": {
            "type": "string"
          },
          "title": "Required Routes",
          "type": "array"
        },
        "residual_ledger": {
          "$ref": "#/$defs/Ledger"
        },
        "risk_charge": {
          "default": 0.0,
          "title": "Risk Charge",
          "type": "number"
        },
        "rollback_condition": {
          "default": "no-positive-finite-gain",
          "title": "Rollback Condition",
          "type": "string"
        },
        "score": {
          "default": 0.0,
          "title": "Score",
          "type": "number"
        },
        "target_component": {
          "title": "Target Component",
          "type": "string"
        },
        "verification_cost": {
          "default": 0.0,
          "title": "Verification Cost",
          "type": "number"
        }
      },
      "required": [
        "intervention_id",
        "target_component",
        "action_kind"
      ],
      "title": "BottleneckIntervention",
      "type": "object"
    },
    "BottleneckInversionPlan": {
      "description": "Ranked plan for improving limiting ECPT proxy components.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "after_psi_lower_bound": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "After Psi Lower Bound",
          "type": "object"
        },
        "before_psi": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Before Psi",
          "type": "object"
        },
        "interventions": {
          "items": {
            "$ref": "#/$defs/BottleneckIntervention"
          },
          "title": "Interventions",
          "type": "array"
        },
        "limiting_components": {
          "items": {
            "type": "string"
          },
          "title": "Limiting Components",
          "type": "array"
        },
        "plan_id": {
          "title": "Plan Id",
          "type": "string"
        },
        "residual_ledger": {
          "$ref": "#/$defs/Ledger"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        }
      },
      "required": [
        "plan_id"
      ],
      "title": "BottleneckInversionPlan",
      "type": "object"
    },
    "CapabilityPacketCandidate": {
      "description": "An observable artifact that may become an ECPT capability packet.",
      "properties": {
        "authority_granted": {
          "default": true,
          "title": "Authority Granted",
          "type": "boolean"
        },
        "authority_required": {
          "default": false,
          "title": "Authority Required",
          "type": "boolean"
        },
        "claim": {
          "title": "Claim",
          "type": "string"
        },
        "content_sha256": {
          "title": "Content Sha256",
          "type": "string"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "evidence_hash_valid": {
          "default": true,
          "title": "Evidence Hash Valid",
          "type": "boolean"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "expected_downstream_gain": {
          "default": 0.0,
          "title": "Expected Downstream Gain",
          "type": "number"
        },
        "expires_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires At"
        },
        "freshness": {
          "default": 1.0,
          "title": "Freshness",
          "type": "number"
        },
        "hazard_charge": {
          "default": 0.0,
          "title": "Hazard Charge",
          "type": "number"
        },
        "identity_contribution_status": {
          "$ref": "#/$defs/IdentityContributionStatus",
          "default": "provisional"
        },
        "issuer_agent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Issuer Agent Id"
        },
        "issuer_attestation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Issuer Attestation Id"
        },
        "issuer_public_key_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Issuer Public Key Id"
        },
        "issuer_signature_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Issuer Signature Ref"
        },
        "packet_id": {
          "title": "Packet Id",
          "type": "string"
        },
        "receiver_family": {
          "items": {
            "type": "string"
          },
          "title": "Receiver Family",
          "type": "array"
        },
        "residual_charge": {
          "default": 0.0,
          "title": "Residual Charge",
          "type": "number"
        },
        "reuse_context": {
          "default": "general",
          "title": "Reuse Context",
          "type": "string"
        },
        "rollback_available": {
          "default": true,
          "title": "Rollback Available",
          "type": "boolean"
        },
        "route_safe": {
          "default": true,
          "title": "Route Safe",
          "type": "boolean"
        },
        "salience_class": {
          "default": "default",
          "title": "Salience Class",
          "type": "string"
        },
        "source_kind": {
          "$ref": "#/$defs/PacketSourceKind",
          "default": "local"
        },
        "source_ref": {
          "title": "Source Ref",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ClaimStatus",
          "default": "provisional"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "verification_cost": {
          "default": 0.0,
          "title": "Verification Cost",
          "type": "number"
        },
        "verifier_routes": {
          "items": {
            "type": "string"
          },
          "title": "Verifier Routes",
          "type": "array"
        }
      },
      "required": [
        "packet_id",
        "source_ref",
        "content_sha256",
        "claim"
      ],
      "title": "CapabilityPacketCandidate",
      "type": "object"
    },
    "CapabilityPacketRegistry": {
      "description": "Deterministic packet registry for an ECPT packet ecology run.",
      "properties": {
        "edges": {
          "items": {
            "$ref": "#/$defs/EdgeWitness"
          },
          "title": "Edges",
          "type": "array"
        },
        "packets": {
          "items": {
            "$ref": "#/$defs/CapabilityPacketCandidate"
          },
          "title": "Packets",
          "type": "array"
        },
        "registry_id": {
          "title": "Registry Id",
          "type": "string"
        },
        "residual_ledger": {
          "$ref": "#/$defs/Ledger"
        }
      },
      "required": [
        "registry_id"
      ],
      "title": "CapabilityPacketRegistry",
      "type": "object"
    },
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EdgeWitness": {
      "description": "Finite witness that one or more packets support another packet or receiver.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "confidence": {
          "default": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "edge_id": {
          "title": "Edge Id",
          "type": "string"
        },
        "edge_type": {
          "default": "semantic-dependency",
          "title": "Edge Type",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "expires_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires At"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "residual": {
          "default": 0.0,
          "title": "Residual",
          "type": "number"
        },
        "source_packet_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Packet Ids",
          "type": "array"
        },
        "target_packet_id": {
          "title": "Target Packet Id",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "source_packet_ids",
        "target_packet_id"
      ],
      "title": "EdgeWitness",
      "type": "object"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "IdentityContributionStatus": {
      "description": "How identity evidence may contribute to runtime packet capital.",
      "enum": [
        "verified",
        "provisional",
        "diagnostic",
        "quarantined",
        "rejected"
      ],
      "title": "IdentityContributionStatus",
      "type": "string"
    },
    "IntakeProvenanceRecord": {
      "description": "Sanitized provenance for external packet candidates.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "byte_count": {
          "default": 0,
          "title": "Byte Count",
          "type": "integer"
        },
        "content_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "final_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Final Url"
        },
        "media_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Type"
        },
        "provenance_id": {
          "title": "Provenance Id",
          "type": "string"
        },
        "public_source_ref": {
          "title": "Public Source Ref",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "redirect_chain": {
          "items": {
            "type": "string"
          },
          "title": "Redirect Chain",
          "type": "array"
        },
        "residual_coordinates": {
          "items": {
            "type": "string"
          },
          "title": "Residual Coordinates",
          "type": "array"
        },
        "robots_decision": {
          "anyOf": [
            {
              "$ref": "#/$defs/RobotsDecision"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_kind": {
          "$ref": "#/$defs/PacketSourceKind"
        },
        "source_ref": {
          "title": "Source Ref",
          "type": "string"
        },
        "status_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status Code"
        }
      },
      "required": [
        "provenance_id",
        "source_kind",
        "source_ref",
        "public_source_ref"
      ],
      "title": "IntakeProvenanceRecord",
      "type": "object"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    },
    "PacketIngestionReport": {
      "description": "Packet ingestion result for local, live, or agent-output sources.",
      "properties": {
        "accepted": {
          "title": "Accepted",
          "type": "boolean"
        },
        "packets": {
          "items": {
            "$ref": "#/$defs/CapabilityPacketCandidate"
          },
          "title": "Packets",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/IntakeProvenanceRecord"
          },
          "title": "Provenance",
          "type": "array"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "rejected_sources": {
          "items": {
            "type": "string"
          },
          "title": "Rejected Sources",
          "type": "array"
        },
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "residual_ledger": {
          "$ref": "#/$defs/Ledger"
        },
        "source_kind": {
          "$ref": "#/$defs/PacketSourceKind"
        },
        "web_fetch_reports": {
          "items": {
            "$ref": "#/$defs/WebFetchReport"
          },
          "title": "Web Fetch Reports",
          "type": "array"
        }
      },
      "required": [
        "report_id",
        "accepted",
        "source_kind"
      ],
      "title": "PacketIngestionReport",
      "type": "object"
    },
    "PacketSourceKind": {
      "enum": [
        "local",
        "github",
        "zenodo",
        "arxiv",
        "http",
        "web-page",
        "rss",
        "atom",
        "json-feed",
        "ndjson",
        "agent-message",
        "agent-inbox",
        "web-crawl",
        "agent-output",
        "auto"
      ],
      "title": "PacketSourceKind",
      "type": "string"
    },
    "PsiDashboard": {
      "description": "ECPT ASI-proxy phase bundle dashboard.",
      "properties": {
        "components": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Components",
          "type": "object"
        },
        "dashboard_id": {
          "title": "Dashboard Id",
          "type": "string"
        },
        "distance_to_threshold": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Distance To Threshold",
          "type": "object"
        },
        "limiting_components": {
          "items": {
            "type": "string"
          },
          "title": "Limiting Components",
          "type": "array"
        },
        "residual_ledger": {
          "$ref": "#/$defs/Ledger"
        },
        "safety_invariants": {
          "items": {
            "type": "string"
          },
          "title": "Safety Invariants",
          "type": "array"
        },
        "threshold": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Threshold",
          "type": "object"
        },
        "throughput": {
          "$ref": "#/$defs/VerificationThroughputReport"
        }
      },
      "required": [
        "dashboard_id",
        "components",
        "threshold",
        "distance_to_threshold"
      ],
      "title": "PsiDashboard",
      "type": "object"
    },
    "RobotsDecision": {
      "description": "Recorded robots/rate decision for bounded web intake.\n\nThis is an audit record, not a guarantee that the remote site authorizes\nevery downstream use.  Unknown or unavailable policy can remain diagnostic\nunder stricter profiles.",
      "properties": {
        "allowed": {
          "default": true,
          "title": "Allowed",
          "type": "boolean"
        },
        "decision_id": {
          "default": "robots:not-checked",
          "title": "Decision Id",
          "type": "string"
        },
        "mode": {
          "default": "not-checked",
          "title": "Mode",
          "type": "string"
        },
        "reason": {
          "default": "robots policy was recorded but not enforced",
          "title": "Reason",
          "type": "string"
        },
        "residual_coordinate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Residual Coordinate"
        },
        "source_ref": {
          "default": "",
          "title": "Source Ref",
          "type": "string"
        }
      },
      "title": "RobotsDecision",
      "type": "object"
    },
    "VerificationThroughputReport": {
      "description": "Finite throughput dashboard for verifier queue health.",
      "properties": {
        "abstained_packets": {
          "default": 0,
          "title": "Abstained Packets",
          "type": "integer"
        },
        "accepted_packets": {
          "default": 0,
          "title": "Accepted Packets",
          "type": "integer"
        },
        "evidence_hash_mismatch_rate": {
          "default": 0.0,
          "title": "Evidence Hash Mismatch Rate",
          "type": "number"
        },
        "false_liquidity_rate": {
          "default": 0.0,
          "title": "False Liquidity Rate",
          "type": "number"
        },
        "low_contribution_queue_occupation": {
          "default": 0.0,
          "title": "Low Contribution Queue Occupation",
          "type": "number"
        },
        "packet_inflow": {
          "default": 0,
          "title": "Packet Inflow",
          "type": "integer"
        },
        "rejected_packets": {
          "default": 0,
          "title": "Rejected Packets",
          "type": "integer"
        },
        "residual_debt_growth": {
          "default": 0.0,
          "title": "Residual Debt Growth",
          "type": "number"
        },
        "stale_packet_ratio": {
          "default": 0.0,
          "title": "Stale Packet Ratio",
          "type": "number"
        },
        "unresolved_obligation_backlog": {
          "default": 0,
          "title": "Unresolved Obligation Backlog",
          "type": "integer"
        },
        "verifier_latency_proxy": {
          "default": 0.0,
          "title": "Verifier Latency Proxy",
          "type": "number"
        }
      },
      "title": "VerificationThroughputReport",
      "type": "object"
    },
    "WebFetchReport": {
      "description": "Portable audit record for one bounded HTTP(S) resource fetch.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "byte_count": {
          "default": 0,
          "title": "Byte Count",
          "type": "integer"
        },
        "content_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "content_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Type"
        },
        "final_url": {
          "default": "",
          "title": "Final Url",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "redirect_chain": {
          "items": {
            "type": "string"
          },
          "title": "Redirect Chain",
          "type": "array"
        },
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "requested_url": {
          "title": "Requested Url",
          "type": "string"
        },
        "robots_decision": {
          "$ref": "#/$defs/RobotsDecision"
        },
        "status_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status Code"
        }
      },
      "required": [
        "report_id",
        "requested_url"
      ],
      "title": "WebFetchReport",
      "type": "object"
    }
  },
  "description": "One closed-loop packet ecology iteration around an agent output.",
  "properties": {
    "ingestion": {
      "$ref": "#/$defs/PacketIngestionReport"
    },
    "iteration_id": {
      "title": "Iteration Id",
      "type": "string"
    },
    "next_agent_tasks": {
      "items": {
        "type": "string"
      },
      "title": "Next Agent Tasks",
      "type": "array"
    },
