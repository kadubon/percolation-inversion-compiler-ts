    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "affected_ecpt_components": {
      "items": {
        "type": "string"
      },
      "title": "Affected Ecpt Components",
      "type": "array"
    },
    "blockers": {
      "items": {
        "$ref": "#/$defs/AltLiftBlocker"
      },
      "title": "Blockers",
      "type": "array"
    },
    "capital_to_path_contributions": {
      "items": {
        "$ref": "#/$defs/CapitalToPathContribution"
      },
      "title": "Capital To Path Contributions",
      "type": "array"
    },
    "cross_context_transfer_witnesses": {
      "items": {
        "$ref": "#/$defs/CrossContextTransferWitness"
      },
      "title": "Cross Context Transfer Witnesses",
      "type": "array"
    },
    "diagnostic_only_lift_failure": {
      "default": true,
      "title": "Diagnostic Only Lift Failure",
      "type": "boolean"
    },
    "downstream_search_cost_deltas": {
      "items": {
        "$ref": "#/$defs/DownstreamSearchCostDelta"
      },
      "title": "Downstream Search Cost Deltas",
      "type": "array"
    },
    "graph_id": {
      "default": "",
      "title": "Graph Id",
      "type": "string"
