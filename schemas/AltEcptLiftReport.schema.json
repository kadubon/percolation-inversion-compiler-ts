        "packet_id": {
          "default": "",
          "title": "Packet Id",
          "type": "string"
        },
        "receiver_context_id": {
          "default": "",
          "title": "Receiver Context Id",
          "type": "string"
        },
        "receiver_context_present": {
          "default": false,
          "title": "Receiver Context Present",
          "type": "boolean"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        }
      },
      "required": [
        "lift_id"
      ],
      "title": "ReceiverLiquidityLift",
      "type": "object"
