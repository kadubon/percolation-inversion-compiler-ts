        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "residuals_preserved": {
          "default": true,
          "title": "Residuals Preserved",
          "type": "boolean"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        },
        "source_context": {
          "default": "",
          "title": "Source Context",
          "type": "string"
        },
        "target_context": {
          "default": "",
          "title": "Target Context",
          "type": "string"
        },
        "transfer_supported": {
          "default": false,
          "title": "Transfer Supported",
          "type": "boolean"
        },
        "witness_id": {
          "title": "Witness Id",
          "type": "string"
        }
      },
      "required": [
        "witness_id"
      ],
      "title": "CrossContextTransferWitness",
      "type": "object"
    },
    "DownstreamSearchCostDelta": {
      "description": "Finite downstream search-cost delta claimed by an ALT token.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "baseline_cost": {
          "default": 0.0,
          "title": "Baseline Cost",
          "type": "number"
        },
        "candidate_cost": {
          "default": 0.0,
          "title": "Candidate Cost",
          "type": "number"
