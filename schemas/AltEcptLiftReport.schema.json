    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "receiver_liquidity_lifts": {
      "items": {
        "$ref": "#/$defs/ReceiverLiquidityLift"
      },
      "title": "Receiver Liquidity Lifts",
      "type": "array"
