        "graph_id": {
          "default": "",
          "title": "Graph Id",
          "type": "string"
        },
        "packet_id": {
          "default": "",
          "title": "Packet Id",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        },
        "supports_closure": {
          "default": false,
          "title": "Supports Closure",
          "type": "boolean"
        }
      },
      "required": [
        "contribution_id"
      ],
      "title": "LiquidityToClosureContribution",
      "type": "object"
    },
    "ReceiverLiquidityLift": {
      "description": "Receiver-context contribution from ALT abstraction liquidity.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "blockers": {
          "items": {
            "type": "string"
          },
          "title": "Blockers",
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "improves_receiver_context": {
          "default": false,
          "title": "Improves Receiver Context",
          "type": "boolean"
