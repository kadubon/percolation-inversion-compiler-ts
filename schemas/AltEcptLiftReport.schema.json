{
  "$defs": {
    "AltLiftBlocker": {
      "description": "Reason an ALT artifact did not lift into ECPT phase components.",
      "properties": {
        "blocker_id": {
          "title": "Blocker Id",
          "type": "string"
        },
        "blocker_type": {
          "title": "Blocker Type",
          "type": "string"
        },
        "packet_id": {
          "default": "",
          "title": "Packet Id",
          "type": "string"
        },
        "remediation": {
          "default": "",
          "title": "Remediation",
          "type": "string"
        },
        "residual_preserved": {
          "default": true,
          "title": "Residual Preserved",
          "type": "boolean"
        }
      },
      "required": [
        "blocker_id",
        "blocker_type"
      ],
      "title": "AltLiftBlocker",
      "type": "object"
    },
    "CapitalToPathContribution": {
      "description": "Contribution from certified abstraction capital to execution path density.",
      "properties": {
        "accepted": {
          "default": false,
          "title": "Accepted",
          "type": "boolean"
        },
        "contribution_id": {
          "title": "Contribution Id",
          "type": "string"
        },
        "graph_id": {
          "default": "",
          "title": "Graph Id",
          "type": "string"
        },
        "increases_execution_available_path_density": {
          "default": false,
          "title": "Increases Execution Available Path Density",
          "type": "boolean"
        },
        "packet_id": {
          "default": "",
          "title": "Packet Id",
          "type": "string"
        },
        "path_ids": {
          "items": {
            "type": "string"
          },
          "title": "Path Ids",
          "type": "array"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "settled": {
          "default": false,
          "title": "Settled",
          "type": "boolean"
        }
      },
      "required": [
        "contribution_id"
      ],
      "title": "CapitalToPathContribution",
      "type": "object"
    },
    "CrossContextTransferWitness": {
      "description": "Witness that ALT capital transfers across declared receiver contexts.",
