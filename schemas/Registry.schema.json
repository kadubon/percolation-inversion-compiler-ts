{
  "$defs": {
    "ClaimRecord": {
      "description": "Machine-readable claim projection.",
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact"
        },
        "citation_keys": {
          "items": {
            "type": "string"
          },
          "title": "Citation Keys",
          "type": "array"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "declared_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dependency_labels": {
          "items": {
            "type": "string"
          },
          "title": "Dependency Labels",
          "type": "array"
        },
        "derived_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "domain": {
          "anyOf": [
            {
              "$ref": "#/$defs/ValidityDomain"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "ledger_coordinates": {
          "items": {
            "type": "string"
          },
          "title": "Ledger Coordinates",
          "type": "array"
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status_outputs": {
          "items": {
            "$ref": "#/$defs/ClaimStatus"
          },
          "title": "Status Outputs",
          "type": "array"
        }
      },
      "required": [
        "claim_id",
        "kind",
        "label"
      ],
      "title": "ClaimRecord",
      "type": "object"
    },
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "ValidityDomain": {
      "description": "A declared finite domain for one extracted claim.",
      "properties": {
        "identifier": {
          "title": "Identifier",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "observation_window": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observation Window"
        },
        "protocol_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Protocol Scope"
        },
        "receiver_family": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Receiver Family"
        },
        "target_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Basis"
        }
      },
      "required": [
        "identifier"
      ],
      "title": "ValidityDomain",
      "type": "object"
    }
  },
  "description": "Finite claim registry extracted from a source artifact.",
  "properties": {
    "artifact": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/ClaimRecord"
      },
      "title": "Claims",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "default": "registry-1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "title": "Registry",
  "type": "object"
}
