{
  "$defs": {
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "description": "Fail-closed verification report for identity or attestation evidence.",
  "properties": {
    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "agent_id": {
      "title": "Agent Id",
      "type": "string"
    },
    "digest_valid": {
      "default": false,
      "title": "Digest Valid",
      "type": "boolean"
    },
    "fingerprint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fingerprint"
    },
    "fingerprint_valid": {
      "default": false,
      "title": "Fingerprint Valid",
      "type": "boolean"
    },
    "finite_checks_passed": {
      "default": false,
      "title": "Finite Checks Passed",
      "type": "boolean"
    },
    "key_valid": {
      "default": false,
      "title": "Key Valid",
      "type": "boolean"
    },
    "non_expired": {
      "default": false,
      "title": "Non Expired",
      "type": "boolean"
    },
    "non_revoked": {
      "default": false,
      "title": "Non Revoked",
      "type": "boolean"
    },
    "operationally_usable": {
      "default": false,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "payload_digest": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Payload Digest"
    },
    "policy_digest_present": {
      "default": false,
      "title": "Policy Digest Present",
      "type": "boolean"
    },
    "public_key_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Public Key Id"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "report_id": {
      "title": "Report Id",
      "type": "string"
    },
    "residual_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "signature_suite": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Signature Suite"
    },
    "signature_valid": {
      "default": false,
      "title": "Signature Valid",
      "type": "boolean"
    }
  },
  "required": [
    "report_id",
    "agent_id"
  ],
  "title": "AgentIdentityCheckReport",
  "type": "object"
}
