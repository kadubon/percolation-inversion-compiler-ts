{
  "$defs": {
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "description": "Finite protocol-relative acceleration certificate against a baseline.",
  "properties": {
    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "baseline_run_id": {
      "title": "Baseline Run Id",
      "type": "string"
    },
    "candidate_run_id": {
      "title": "Candidate Run Id",
      "type": "string"
    },
    "certificate_id": {
      "title": "Certificate Id",
      "type": "string"
    },
    "false_liquidity_bounded": {
      "default": false,
      "title": "False Liquidity Bounded",
      "type": "boolean"
    },
    "finite_checks_passed": {
      "default": false,
      "title": "Finite Checks Passed",
      "type": "boolean"
    },
    "hitting_time_gain_lower_bound": {
      "default": 0.0,
      "title": "Hitting Time Gain Lower Bound",
      "type": "number"
    },
    "operationally_usable": {
      "default": false,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "psi_distance_reduction_lower_bound": {
      "default": 0.0,
      "title": "Psi Distance Reduction Lower Bound",
      "type": "number"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "residual_external_obligations": {
      "items": {
        "type": "string"
      },
      "title": "Residual External Obligations",
      "type": "array"
    },
    "residual_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "resource_envelope_matched": {
      "default": false,
      "title": "Resource Envelope Matched",
      "type": "boolean"
    },
    "resource_matched": {
      "default": false,
      "title": "Resource Matched",
      "type": "boolean"
    },
    "salience_non_obstructed": {
      "default": false,
      "title": "Salience Non Obstructed",
      "type": "boolean"
    },
    "score_gain_lower_bound": {
      "default": 0.0,
      "title": "Score Gain Lower Bound",
      "type": "number"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "tau_baseline": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tau Baseline"
    },
    "tau_candidate": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tau Candidate"
    },
    "threshold": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Threshold",
      "type": "object"
    },
    "verification_backlog_bounded": {
      "default": false,
      "title": "Verification Backlog Bounded",
      "type": "boolean"
    }
  },
  "required": [
    "certificate_id",
    "baseline_run_id",
    "candidate_run_id"
  ],
  "title": "AccelerationCertificate",
  "type": "object"
}
