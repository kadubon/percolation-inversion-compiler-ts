{
  "$defs": {
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "DischargeLevel": {
      "enum": [
        "finite_value_check",
        "replay_check",
        "contract_enforced",
        "external_domain_required"
      ],
      "title": "DischargeLevel",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "EvidenceVerificationProfile": {
      "enum": [
        "development",
        "research",
        "production"
      ],
      "title": "EvidenceVerificationProfile",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "description": "Adapter-route resolution result that preserves safe failure behavior.",
  "properties": {
    "accepted": {
      "title": "Accepted",
      "type": "boolean"
    },
    "accepted_obligation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Accepted Obligation Ids",
      "type": "array"
    },
    "availability": {
      "title": "Availability",
      "type": "string"
    },
    "binding_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Binding Id"
    },
    "discharge_level": {
      "$ref": "#/$defs/DischargeLevel",
      "default": "external_domain_required"
    },
    "domain_witness_required": {
      "default": false,
      "title": "Domain Witness Required",
      "type": "boolean"
    },
    "evidence_artifact_ids": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Artifact Ids",
      "type": "array"
    },
    "evidence_envelope_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Evidence Envelope Id"
    },
    "finite_scope_usable": {
      "default": false,
      "title": "Finite Scope Usable",
      "type": "boolean"
    },
    "missing_evidence_kind": {
      "items": {
        "type": "string"
      },
      "title": "Missing Evidence Kind",
      "type": "array"
    },
    "operationally_usable": {
      "default": false,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "profile": {
      "$ref": "#/$defs/EvidenceVerificationProfile",
      "default": "development"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "rejected_obligation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Rejected Obligation Ids",
      "type": "array"
    },
    "residual_external_obligations": {
      "items": {
        "type": "string"
      },
      "title": "Residual External Obligations",
      "type": "array"
    },
    "residual_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "resolution_digest": {
      "title": "Resolution Digest",
      "type": "string"
    },
    "resolution_id": {
      "title": "Resolution Id",
      "type": "string"
    },
    "route_id": {
      "title": "Route Id",
      "type": "string"
    },
    "safe_default": {
      "default": "diagnostic-with-unresolved-obligations",
      "title": "Safe Default",
      "type": "string"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "settled_scope": {
      "items": {
        "type": "string"
      },
      "title": "Settled Scope",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/ClaimStatus"
    }
  },
  "required": [
    "resolution_id",
    "route_id",
    "accepted",
    "status",
    "availability",
    "resolution_digest"
  ],
  "title": "VerifierResolution",
  "type": "object"
}
