{
  "description": "Finite certificate candidate for a proposed BIT inversion.",
  "properties": {
    "candidate_id": {
      "title": "Candidate Id",
      "type": "string"
    },
    "certificate_id": {
      "title": "Certificate Id",
      "type": "string"
    },
    "certificate_status": {
      "default": "abstain",
      "title": "Certificate Status",
      "type": "string"
    },
    "finite_requirements_passed": {
      "default": false,
      "title": "Finite Requirements Passed",
      "type": "boolean"
    },
    "grants_execution_authority": {
      "default": false,
      "title": "Grants Execution Authority",
      "type": "boolean"
    },
    "protocol_relative_only": {
      "default": true,
      "title": "Protocol Relative Only",
      "type": "boolean"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "residual_preserved": {
      "default": true,
      "title": "Residual Preserved",
      "type": "boolean"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    }
