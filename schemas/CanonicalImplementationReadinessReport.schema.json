        "mr_records": {
          "default": 0,
          "title": "Mr Records",
          "type": "integer"
        },
        "partial_total": {
          "default": 0,
          "title": "Partial Total",
          "type": "integer"
        },
        "portability_status": {
          "default": "schema-first",
          "title": "Portability Status",
          "type": "string"
        },
        "source_tex_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Tex Sha256"
        },
        "unsupported_total": {
          "default": 0,
          "title": "Unsupported Total",
          "type": "integer"
        }
      },
      "required": [
        "artifact_key",
        "artifact"
      ],
      "title": "CanonicalTheorySnapshotSummary",
      "type": "object"
    }
  },
