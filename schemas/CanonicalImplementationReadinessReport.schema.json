            "type": "integer"
          },
          "title": "Coverage Counts",
          "type": "object"
        },
        "definitions": {
          "default": 0,
          "title": "Definitions",
          "type": "integer"
        },
        "doi": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doi"
        },
        "external_obligation_category_summary": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "External Obligation Category Summary",
          "type": "object"
        },
        "external_obligation_total": {
          "default": 0,
          "title": "External Obligation Total",
          "type": "integer"
        },
        "finite_upgrade_candidate_count": {
          "default": 0,
