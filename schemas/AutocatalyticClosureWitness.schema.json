{
  "$defs": {
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "description": "Accepted finite closure witness for ECPT collective packet regeneration.",
  "properties": {
    "accepted": {
      "default": false,
      "title": "Accepted",
      "type": "boolean"
    },
    "closure_packet_ids": {
      "items": {
        "type": "string"
      },
      "title": "Closure Packet Ids",
      "type": "array"
    },
    "closure_strength": {
      "default": 0.0,
      "title": "Closure Strength",
      "type": "number"
    },
    "external_seed_packet_ids": {
      "items": {
        "type": "string"
      },
      "title": "External Seed Packet Ids",
      "type": "array"
    },
    "false_liquidity_rate": {
      "default": 0.0,
      "title": "False Liquidity Rate",
      "type": "number"
    },
    "finite_checks_passed": {
      "default": false,
      "title": "Finite Checks Passed",
      "type": "boolean"
    },
    "internal_edge_ids": {
      "items": {
        "type": "string"
      },
      "title": "Internal Edge Ids",
      "type": "array"
    },
    "operationally_usable": {
      "default": false,
      "title": "Operationally Usable",
      "type": "boolean"
    },
    "productive_packet_ids": {
      "items": {
        "type": "string"
      },
      "title": "Productive Packet Ids",
      "type": "array"
    },
    "productivity_lower_bound": {
      "default": 0.0,
      "title": "Productivity Lower Bound",
      "type": "number"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "regeneration_edge_ids": {
      "items": {
        "type": "string"
      },
      "title": "Regeneration Edge Ids",
      "type": "array"
    },
    "residual_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "settled": {
      "default": false,
      "title": "Settled",
      "type": "boolean"
    },
    "witness_id": {
      "title": "Witness Id",
      "type": "string"
    }
  },
  "required": [
    "witness_id"
  ],
  "title": "AutocatalyticClosureWitness",
  "type": "object"
}
