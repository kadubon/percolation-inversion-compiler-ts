{
  "$defs": {
    "CapabilityPacket": {
      "properties": {
        "burden": {
          "default": 0.0,
          "title": "Burden",
          "type": "number"
        },
        "coordinates": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Coordinates",
          "type": "object"
        },
        "duplicate_mass": {
          "default": 0.0,
          "title": "Duplicate Mass",
          "type": "number"
        },
        "packet_id": {
          "title": "Packet Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ClaimStatus",
          "default": "provisional"
        },
        "validity_domain": {
          "default": "global",
          "title": "Validity Domain",
          "type": "string"
        }
      },
      "required": [
        "packet_id"
      ],
      "title": "CapabilityPacket",
      "type": "object"
    },
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    }
  },
  "properties": {
    "burden_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "packets": {
      "items": {
        "$ref": "#/$defs/CapabilityPacket"
      },
      "title": "Packets",
      "type": "array"
    },
    "validity_domain": {
      "default": "global",
      "title": "Validity Domain",
      "type": "string"
    }
  },
  "title": "CapabilityStateVector",
  "type": "object"
}
