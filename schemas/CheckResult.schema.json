{
  "$defs": {
    "ClaimRecord": {
      "description": "Machine-readable claim projection.",
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact"
        },
        "citation_keys": {
          "items": {
            "type": "string"
          },
          "title": "Citation Keys",
          "type": "array"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "declared_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dependency_labels": {
          "items": {
            "type": "string"
          },
          "title": "Dependency Labels",
          "type": "array"
        },
        "derived_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "domain": {
          "anyOf": [
            {
              "$ref": "#/$defs/ValidityDomain"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "ledger_coordinates": {
          "items": {
            "type": "string"
          },
          "title": "Ledger Coordinates",
          "type": "array"
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status_outputs": {
          "items": {
            "$ref": "#/$defs/ClaimStatus"
          },
          "title": "Status Outputs",
          "type": "array"
        }
      },
      "required": [
        "claim_id",
        "kind",
        "label"
      ],
      "title": "ClaimRecord",
      "type": "object"
    },
    "ClaimStatus": {
      "description": "Protocol-relative status labels used by ECPT, BIT, TRC, SQOT, and ALT.",
      "enum": [
        "rejected",
        "expired",
        "diagnostic",
        "relaxed",
        "risk-provisional",
        "speculative",
        "provisional",
        "partial",
        "settled"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "CoordinateKind": {
      "enum": [
        "benefit",
        "burden",
        "residual",
        "tolerance",
        "resource",
        "metadata"
      ],
      "title": "CoordinateKind",
      "type": "string"
    },
    "EvidenceStatus": {
      "enum": [
        "verified",
        "declared",
        "unknown"
      ],
      "title": "EvidenceStatus",
      "type": "string"
    },
    "Ledger": {
      "description": "A finite typed ledger with explicit coordinate kinds.",
      "properties": {
        "coordinates": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerCoordinate"
          },
          "title": "Coordinates",
          "type": "object"
        }
      },
      "title": "Ledger",
      "type": "object"
    },
    "LedgerCoordinate": {
      "description": "One typed coordinate in a finite certificate ledger.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "$ref": "#/$defs/EvidenceStatus",
          "default": "declared"
        },
        "kind": {
          "$ref": "#/$defs/CoordinateKind",
          "default": "burden"
        },
        "known": {
          "default": true,
          "title": "Known",
          "type": "boolean"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "unit": {
          "default": "dimensionless",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "LedgerCoordinate",
      "type": "object"
    },
    "ValidityDomain": {
      "description": "A declared finite domain for one extracted claim.",
      "properties": {
        "identifier": {
          "title": "Identifier",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "observation_window": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observation Window"
        },
        "protocol_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Protocol Scope"
        },
        "receiver_family": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Receiver Family"
        },
        "target_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Basis"
        }
      },
      "required": [
        "identifier"
      ],
      "title": "ValidityDomain",
      "type": "object"
    }
  },
  "description": "Result of a finite checker call.",
  "properties": {
    "accepted": {
      "title": "Accepted",
      "type": "boolean"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/ClaimRecord"
      },
      "title": "Claims",
      "type": "array"
    },
    "finite_checks_passed": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finite Checks Passed"
    },
    "missing_obligations": {
      "items": {
        "type": "string"
      },
      "title": "Missing Obligations",
      "type": "array"
    },
    "operationally_usable": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Operationally Usable"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "residual_ledger": {
      "$ref": "#/$defs/Ledger"
    },
    "schema_valid": {
      "default": true,
      "title": "Schema Valid",
      "type": "boolean"
    },
    "settled": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Settled"
    },
    "status": {
      "$ref": "#/$defs/ClaimStatus"
    }
  },
  "required": [
    "accepted",
    "status"
  ],
  "title": "CheckResult",
  "type": "object"
}
