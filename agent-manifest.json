{
  "manifest_id": "pic-ts-agent-manifest-v090",
  "package_name": "percolation-inversion-compiler-ts",
  "version": "0.9.0",
  "recommended_cli": "pic-ts",
  "compatibility_alias": "pic",
  "canonical_python_package": "percolation-inversion-compiler==0.9.0",
  "purpose": "Local JSON checker and workflow report generator for JavaScript and TypeScript agent runtimes.",
  "safe_entrypoints": [
    "pic-ts agent check --compact",
    "pic-ts runtime step --state <state.json> --input <input.json>",
    "pic-ts packet export --report <report.json> --output <packet.json>",
    "pic-ts packet inspect --packet <packet.json>",
    "pic-ts phase lab init --output-dir <phase-lab-dir>",
    "pic-ts phase lab ingest --store <phase-lab-dir> --report <report.json>",
    "pic-ts phase lab observe --store <phase-lab-dir> --window latest",
    "pic-ts phase lab graph --store <phase-lab-dir>",
    "pic-ts phase lab closure --store <phase-lab-dir>",
    "pic-ts phase lab executable-paths --store <phase-lab-dir>",
    "pic-ts phase lab certify --store <phase-lab-dir> --threshold <threshold.json>",
    "pic-ts phase plan --request <request.json> --compact",
    "pic-ts phase plan --request <request.json> --compact --emit ccr-tasks",
    "pic-ts trc trace-normalize --input <trace.json> --output <trace_nf.json>",
    "pic-ts trc trace-check --trace <trace_nf.json>",
    "pic-ts trc operation-gate --trace <trace_nf.json> --provider-profile <profile.json>",
    "pic-ts phase acceleration-report --target <target.json> --baseline <baseline.json> --capital <capital.jsonl>",
    "pic-ts token extract-pipeline --trace <trace.json> --compact",
    "pic-ts token admissibility --token <token.json> --compact",
    "pic-ts performance report --json",
    "pic-ts cache status --json",
    "pic-ts mcp descriptor-check --descriptor <descriptor.json> --profile development",
    "pic-ts a2a handoff-check --handoff <handoff.json> --profile development",
    "pic-ts sqot protocol-integrity --state <state.json>",
    "pic-ts bit mec-frontier --certificates <certificates.jsonl>"
  ],
  "sdk_subpaths": [
    ".",
    "./schema",
    "./agent/messages",
    "./packet",
    "./phase-lab",
    "./bit-engine",
    "./sqot-controller",
    "./alt-lift",
    "./trc-adapter",
    "./interop/ccr"
  ],
  "safety_boundary": {
    "python_required_at_runtime": false,
    "executes_packet_content": false,
    "executes_trace_content": false,
    "grants_shell_authority": false,
    "mutates_repositories": false,
    "uses_live_network_connectors_by_default": false,
    "hidden_settlement": false
  },
  "status_rules": [
    "accepted does not imply settled",
    "workflow_usable does not imply settled",
    "operationally_usable does not imply settled",
    "candidate-only reports remain diagnostic",
    "raw packet volume does not improve positive phase metrics",
    "operation_ready does not imply executed or settled",
    "provider_dispatch_ready does not imply dispatch",
    "physical_dispatch_ready does not imply physical outcome proof",
    "capital_admitted does not imply settled",
    "MCP descriptors and A2A handoffs remain candidate evidence unless checked"
  ]
}
